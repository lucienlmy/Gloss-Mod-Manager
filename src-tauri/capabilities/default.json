{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "core:app:allow-default-window-icon",
        "opener:default",
        "fs:default",
        "notification:default",
        "os:default",
        "clipboard-manager:allow-read-text",
        "clipboard-manager:allow-write-text",
        "shell:allow-execute",
        {
            "identifier": "shell:allow-execute",
            "allow": [
                {
                    "name": "reg",
                    "cmd": "reg",
                    "args": true
                },
                {
                    "name": "cmd",
                    "cmd": "cmd",
                    "args": true
                },
                {
                    "name": "powershell",
                    "cmd": "powershell",
                    "args": true
                }
            ]
        },
        "shell:allow-spawn",
        {
            "identifier": "shell:allow-spawn",
            "allow": [
                {
                    "name": "reg",
                    "cmd": "reg",
                    "args": true
                },
                {
                    "name": "cmd",
                    "cmd": "cmd",
                    "args": true
                },
                {
                    "name": "powershell",
                    "cmd": "powershell",
                    "args": true
                }
            ]
        },
        "shell:allow-kill",
        "shell:allow-stdin-write",
        "shell:allow-open",
        "store:allow-get",
        "store:allow-set",
        "store:allow-save",
        "store:allow-load",
        "stronghold:default",
        "dialog:default",
        "shell:default",
        "core:window:allow-destroy",
        "core:window:allow-unminimize",
        "core:window:allow-hide",
        "core:window:allow-show",
        "core:window:allow-set-focus"
    ]
}
