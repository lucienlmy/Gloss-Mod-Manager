{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Capability for the main window",
    "windows": ["main"],
    "permissions": [
        "core:default",
        "core:app:allow-default-window-icon",
        "opener:default",
        "fs:default",
        "notification:default",
        "os:default",
        "clipboard-manager:allow-read-text",
        "clipboard-manager:allow-write-text",
        {
            "identifier": "shell:allow-execute",
            "allow": [
                {
                    "name": "binaries/sevenzip",
                    "sidecar": true,
                    "args": true
                },
                {
                    "name": "binaries/aria2c",
                    "sidecar": true,
                    "args": true
                }
            ]
        },
        {
            "identifier": "shell:allow-spawn",
            "allow": [
                {
                    "name": "binaries/sevenzip",
                    "sidecar": true,
                    "args": true
                },
                {
                    "name": "binaries/aria2c",
                    "sidecar": true,
                    "args": true
                }
            ]
        },
        {
            "identifier": "shell:allow-kill",
            "allow": [
                {
                    "name": "binaries/sevenzip",
                    "sidecar": true
                },
                {
                    "name": "binaries/aria2c",
                    "sidecar": true
                }
            ]
        },
        "store:allow-get",
        "store:allow-set",
        "store:allow-save",
        "store:allow-load",
        "stronghold:default"
    ]
}
