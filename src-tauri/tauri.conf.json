{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Gloss Mod Manager",
    "version": "2.0.0",
    "identifier": "gmm2.aoe.top",
    "build": {
        "beforeDevCommand": "yarn dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "yarn build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Gloss Mod Manager",
                "width": 1280,
                "height": 720,
                "dragDropEnabled": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "externalBin": ["binaries/sevenzip", "binaries/aria2c"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "nsis": {
                "displayLanguageSelector": true
            }
        }
    },
    "plugins": {
        "cli": {},
        "updater": {
            "endpoints": [
                "https://github.com/GlossMod/Gloss-Mod-Manager/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEYxOUY4RkQ1NTA4MUY1NDUKUldSRjlZRlExWStmOFh0TmNnWi9hNVhJbVZsOWk4eWk0L1JyTldaUEkyMWJzbWFYaG05enpEQ2cK",
            "windows": {
                "installMode": "passive"
            }
        }
    }
}
