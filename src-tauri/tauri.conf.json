{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Gloss Mod Manager",
    "version": "2.0.0",
    "identifier": "gmm2.aoe.top",
    "build": {
        "beforeDevCommand": "yarn dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "yarn build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Gloss Mod Manager",
                "width": 1280,
                "height": 720
            }
        ],
        "security": {
            "csp": null,
            "assetProtocol": {
                "enable": true,
                "scope": ["**"]
            }
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "externalBin": ["binaries/sevenzip", "binaries/aria2c"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    },
    "plugins": {
        "cli": {}
    }
}
