{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Gloss Mod Manager",
    "version": "2.0.11",
    "identifier": "gmm2.aoe.top",
    "build": {
        "beforeDevCommand": "yarn dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "yarn build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "Gloss Mod Manager",
                "width": 1280,
                "height": 720,
                "dragDropEnabled": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "category": "Utility",
        "fileAssociations": [
            {
                "ext": ["gmm"],
                "name": "Gloss Mod Manager Package",
                "description": "Gloss Mod Manager package file",
                "mimeType": "application/x-gloss-mod-manager-package",
                "role": "Editor",
                "exportedType": {
                    "identifier": "top.aoe.gmm2.package",
                    "conformsTo": ["public.data"]
                }
            }
        ],
        "macOS": {
            "minimumSystemVersion": "12.0",
            "entitlements": "entitlements.plist",
            "signingIdentity": "DA1EEC08DE48B2B4B2F4C08B0C608E11AB983375"
        },
        "homepage": "https://github.com/GlossMod/Gloss-Mod-Manager",
        "publisher": "小莫sky",
        "license": "LGPL-3.0-or-later",
        "shortDescription": "A modern game mod manager for fast download, install and update workflows.",
        "copyright": "Copyright (c) 2026 小莫sky",
        "externalBin": ["binaries/sevenzip", "binaries/aria2c"],
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "windows": {
            "allowDowngrades": false,
            "webviewInstallMode": {
                "type": "downloadBootstrapper",
                "silent": true
            },
            "wix": {
                "language": {
                    "en-US": {
                        "localePath": "windows/wix/en-US.wxl"
                    }
                }
            },
            "nsis": {
                "displayLanguageSelector": true,
                "languages": ["SimpChinese", "English"],
                "installerIcon": "icons/icon.ico",
                "headerImage": "windows/installer/header.bmp",
                "sidebarImage": "windows/installer/sidebar.bmp"
            }
        }
    },
    "plugins": {
        "deep-link": {
            "desktop": {
                "schemes": ["gmm", "nxm"]
            }
        },
        "cli": {},
        "updater": {
            "endpoints": [
                "https://github.com/GlossMod/Gloss-Mod-Manager/releases/latest/download/latest.json"
            ],
            "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxMzE2NkQzOTAyQjEyRTUKUldUbEVpdVEwMll4Y1dwejBEUGlYcGRMYm9NcGFoMlpCMkRScGUvZUVNa0Ivek8wYU03WlVQMlUK",
            "windows": {
                "installMode": "quiet"
            }
        }
    }
}
